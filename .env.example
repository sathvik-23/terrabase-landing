# ─────────────────────────────────────────────────────────────
# Waitlist delivery (Resend). All optional in development:
# the /api/waitlist endpoint validates + rate-limits regardless,
# and simply skips email delivery when RESEND_API_KEY is unset.
# ─────────────────────────────────────────────────────────────

# https://resend.com/api-keys
RESEND_API_KEY=

# Optional: a Resend Audience to add waitlist contacts to.
# https://resend.com/audiences
RESEND_AUDIENCE_ID=

# Verified sender. Falls back to Resend's onboarding@resend.dev if unset.
RESEND_FROM_EMAIL="Terrabase <hello@terrabase.dev>"
