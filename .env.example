# ─────────────────────────────────────────────────────────────
# Waitlist storage (Vercel Blob) — powers the admin dashboard.
# Provisioned via `vercel blob create-store` and injected automatically
# on Vercel. Pull locally with `vercel env pull`. Without it, signups
# are accepted but not persisted (and the admin shows a warning).
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# Secret key that gates the /admin dashboard (bookmark ...?k=THIS_VALUE).
# If unset, the dashboard is OPEN and shows a warning. Generate with:
#   openssl rand -hex 24
ADMIN_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────
# Waitlist email delivery (Resend). All optional:
# /api/waitlist validates + rate-limits + stores regardless, and
# simply skips email delivery when RESEND_API_KEY is unset.
# ─────────────────────────────────────────────────────────────

# https://resend.com/api-keys
RESEND_API_KEY=

# Optional: a Resend Audience to add waitlist contacts to.
# https://resend.com/audiences
RESEND_AUDIENCE_ID=

# Verified sender. Falls back to Resend's onboarding@resend.dev if unset.
RESEND_FROM_EMAIL="Terrabase <message@terrabase.in>"
